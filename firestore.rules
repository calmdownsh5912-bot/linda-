rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Global helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Mistake validation
    function isValidMistake(data) {
      return data.keys().hasAll(['userId', 'originalText', 'knowledgePoint', 'createdAt', 'analogousQuestions'])
        && data.userId == request.auth.uid
        && data.originalText is string && data.originalText.size() <= 5000
        && data.knowledgePoint is string && data.knowledgePoint.size() <= 200
        && data.createdAt is timestamp
        && data.analogousQuestions is list
        && data.analogousQuestions.size() <= 10; // Usually 3, but allow some buffer
    }

    match /mistakes/{mistakeId} {
      allow create: if isSignedIn() 
        && isValidId(mistakeId)
        && isValidMistake(incoming())
        && incoming().createdAt == request.time;
      
      allow read: if isOwner(resource.data.userId);

      allow update: if isOwner(resource.data.userId)
        && isValidMistake(incoming())
        && incoming().userId == existing().userId
        && incoming().createdAt == existing().createdAt;

      allow delete: if isOwner(resource.data.userId);
    }
  }
}
